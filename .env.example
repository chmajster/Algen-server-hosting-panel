APP_ENV=production
APP_NAME="Hosting Panel"
APP_HOST=127.0.0.1
APP_PORT=8000
PREFERRED_URL_SCHEME=https
SECRET_KEY=change-this-secret
DATABASE_URL=mysql+pymysql://hosting_panel:change-db-pass@127.0.0.1/hosting_panel
STORAGE_ROOT=/opt/hosting-panel/storage/uploads
BACKUP_ROOT=/opt/hosting-panel/storage/backups
HOSTS_HELPER_PATH=/usr/local/bin/hosting-panel-hosts-helper
HOSTS_BACKUP_DIR=/var/backups/hosting-panel/hosts
HOSTS_SUDO_BIN=/usr/bin/sudo
HOSTS_ALLOWED_FILE=/etc/hosts
SSL_HELPER_PATH=/usr/local/bin/hosting-panel-ssl-helper
LETSENCRYPT_EMAIL=admin@example.com
DEFAULT_TIMEZONE=Europe/Warsaw
RATELIMIT_DEFAULT='200/day;50/hour'
RATELIMIT_STORAGE_URI=memory://
BILLING_GRACE_DAYS=3
BILLING_AUTO_RESUME=true
HOSTS_PROTECT_CRITICAL=true
MAIL_DEFAULT_QUOTA_MB=1024
DEFAULT_PHP_VERSION=8.3
SESSION_COOKIE_SECURE=true
AUTOUPDATE_ENABLED=true
AUTOUPDATE_REPO_URL=https://github.com/chmajster/Algen-server-hosting-panel
AUTOUPDATE_BRANCH=main
AUTOUPDATE_INTERVAL='*:0/15'
